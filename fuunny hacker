import random
import time

jokes = [
    "Why do programmers hate nature? It has too many bugs.",
    "I told my computer I needed a break... it said 'No problem, I'll go to sleep.'",
    "There are 10 types of people: those who understand binary and those who don't.",
    "Debugging: Being the detective in a crime movie where you are also the murderer.",
    "My code works... I have no idea why."
]

roasts = [
    "You write code like it's a mystery novel... nobody understands it.",
    "Your WiFi is faster than your coding logic.",
    "Even Stack Overflow needs time to recover from your questions.",
    "You don't have bugs, you have feature stories."
]

def fake_hack():
    print("\nInitializing system ...\n")

    for i in range(1, 6):
        print(f"Hacking server {i}/5 [OK]")
        time.sleep(0.5)

    print("\nAccessing mainframe...")
    time.sleep(1)

    print("Downloading data... 100%")
    time.sleep(1)

    print("\n❌ ERROR: Just kidding! 😂 You got pranked!\n")

    # Show a joke after the prank
    print("😂 Developer Joke")
    print("-" * 40)
    print(random.choice(jokes))
    print()

def roast_mode():
    print("\n🔥 Roast")
    print("-" * 40)
    print(random.choice(roasts))
    print()

while True:
    print("=" * 40)
    print("      FUN TERMINAL PROJECT")
    print("=" * 40)
    print("1. Fake Hack + Joke")
    print("2. Roast Me")
    print("3. Exit")

    choice = input("\nEnter your choice (1-3): ")

    if choice == "1":
        fake_hack()

    elif choice == "2":
        roast_mode()

    elif choice == "3":
        print("\n👋 Thanks for using the program!")
        break

    else:
        print("\n❌ Invalid choice! Please enter 1, 2, or 3.\n")
